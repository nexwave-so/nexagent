# ══════════════════════════════════════
# NEXWAVE CONNECTION
# ══════════════════════════════════════
NEXWAVE_SIGNALS_URL=https://nexwave.so/api/v1/signals
NEXWAVE_REGIME_URL=https://nexwave.so/api/v1/signals/regime
NEXWAVE_POLL_INTERVAL=30              # Seconds between polls

NEXWAVE_X402_WALLET=                  # Solana wallet address (base58, 44 chars)
NEXWAVE_X402_PRIVATE_KEY=             # Solana signing key — Phantom "Export Private Key" (88 chars)

# ══════════════════════════════════════
# EXECUTION
# ══════════════════════════════════════
EXCHANGE=hyperliquid
HYPERLIQUID_WALLET_ADDRESS=0x...
HYPERLIQUID_PRIVATE_KEY=0x...
PAPER_TRADING=true                    # Start in paper mode — flip to false when ready

# ══════════════════════════════════════
# RISK MANAGEMENT
# ══════════════════════════════════════
MAX_POSITION_USD=500                  # Max notional per trade
RISK_PER_TRADE_PCT=1.0                # % of portfolio risked per signal
DAILY_LOSS_LIMIT_USD=200              # Agent pauses trading when breached
MAX_OPEN_POSITIONS=5                  # Max concurrent positions
MAX_LONG_POSITIONS=0                  # Per-direction cap on longs (0 = no separate cap)
MAX_SHORT_POSITIONS=0                 # Per-direction cap on shorts (0 = no separate cap)
MAX_DAILY_TRADES=20                   # Agent pauses new entries when reached (0 = unlimited)
COOLDOWN_SECONDS=300                  # Per-asset cooldown after a trade
MIN_SIGNAL_STRENGTH=0.7               # Minimum Nexwave signal score to act on
MIN_SIGNAL_CONFIDENCE=0.6             # Minimum confidence threshold

# ══════════════════════════════════════
# EXIT RULES
# ══════════════════════════════════════
EXIT_MODE=hybrid                      # signal | trailing_stop | time | hybrid
STOP_LOSS_PCT_LONG=3.0                # Hard stop for long positions
STOP_LOSS_PCT_SHORT=3.0               # Hard stop for short positions (widen to let shorts run)
TRAILING_STOP_PCT=2.0                 # Trailing stop: X% from high water mark
TAKE_PROFIT_PCT=5.0                   # Take profit target (0 = disabled)
TIME_STOP_HOURS=72                    # Max hold time before forced exit (0 = disabled)
MIN_HOLD_MINUTES=0                    # Skip trailing/TP exits until this many minutes elapsed (0 = disabled)

# ══════════════════════════════════════
# SIGNAL FILTERS
# ══════════════════════════════════════
ALLOWED_SIGNAL_TYPES=funding_rate,oi_divergence,volume_anomaly
ALLOWED_ASSETS=                       # Empty = trade everything Nexwave sends
BLOCKED_ASSETS=FARTCOIN,PENGU         # Never trade these
BLOCK_CRYPTO=false                    # Block plain-symbol signals (no venue prefix = crypto perp)

# ══════════════════════════════════════
# ALERTS (Optional)
# ══════════════════════════════════════
TELEGRAM_BOT_TOKEN=                   # From @BotFather
TELEGRAM_CHAT_ID=                     # Your chat or group ID

# ══════════════════════════════════════
# AGENT
# ══════════════════════════════════════
LOG_LEVEL=INFO
DB_PATH=./nexagent.db
API_PORT=7070
API_BIND=127.0.0.1                    # Use 0.0.0.0 for Render/cloud
API_KEY=                              # Optional: protect FastAPI endpoints
