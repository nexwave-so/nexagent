# ══════════════════════════════════════
# NEXWAVE CONNECTION
# ══════════════════════════════════════
NEXWAVE_SIGNALS_URL=https://nexwave.so/api/v1/signals
NEXWAVE_REGIME_URL=https://nexwave.so/api/v1/signals/regime
NEXWAVE_POLL_INTERVAL=30              # Seconds between polls

NEXWAVE_X402_WALLET=                  # Solana wallet address (base58, 44 chars)
NEXWAVE_X402_PRIVATE_KEY=             # Solana signing key — Phantom "Export Private Key" (88 chars)

# ══════════════════════════════════════
# EXECUTION
# ══════════════════════════════════════
EXCHANGE=hyperliquid
HYPERLIQUID_WALLET_ADDRESS=0x...
HYPERLIQUID_PRIVATE_KEY=0x...
PAPER_TRADING=true                    # Start in paper mode — flip to false when ready

# ══════════════════════════════════════
# RISK MANAGEMENT
# ══════════════════════════════════════
MAX_POSITION_USD=500                  # Max notional per trade
# RISK_PER_TRADE_PCT: % of portfolio per signal. Hyperliquid rejects orders below $10 notional.
# Effective size = portfolio * (pct/100) * regime_multiplier * conviction (floored at 0.5).
# In ranging regime (0.5x) with min conviction (0.5x): need pct >= 2600/portfolio to clear $11 floor.
# Examples: $85 portfolio → 52% minimum; $500 → 9% minimum; $1000 → 4.4% minimum.
RISK_PER_TRADE_PCT=1.0
DAILY_LOSS_LIMIT_USD=200              # Agent pauses trading when breached
MAX_OPEN_POSITIONS=5                  # Max concurrent positions
MAX_LONG_POSITIONS=0                  # Per-direction cap on longs (0 = no separate cap)
MAX_SHORT_POSITIONS=0                 # Per-direction cap on shorts (0 = no separate cap)
MAX_DAILY_TRADES=20                   # Agent pauses new entries when reached (0 = unlimited)
COOLDOWN_SECONDS=120                  # Per-asset cooldown after a trade (faster re-entry for scalps)
LOSS_COOLDOWN_SECONDS=900             # Extra cooldown per asset class after a losing trade
MIN_SIGNAL_STRENGTH=0.7               # Minimum Nexwave signal score to act on
MIN_SIGNAL_CONFIDENCE=0.6             # Minimum confidence threshold
CRYPTO_LONG_STRENGTH_BOOST=0.10       # Extra strength required for crypto longs (historically weak)
MAX_CONSECUTIVE_LOSSES=6              # Auto-pause after N losses in a row (0 = disabled)
MAX_CRYPTO_POSITIONS=2                # Per-class position caps (0 = no limit)
MAX_EQUITY_POSITIONS=2
MAX_COMMODITY_POSITIONS=2

# ══════════════════════════════════════
# EXIT RULES
# ══════════════════════════════════════
EXIT_MODE=hybrid                      # signal | trailing_stop | time | hybrid
# Per-asset-class stops and take-profits (override the global long/short values)
# Scalp architecture: commodity/equity grab 0.3-0.5% moves; crypto needs 3%+ to clear higher fees.
STOP_LOSS_PCT_LONG_CRYPTO=1.5
STOP_LOSS_PCT_SHORT_CRYPTO=1.5
TRAILING_STOP_PCT_CRYPTO=1.5
TAKE_PROFIT_PCT_CRYPTO=3.0           # Crypto fees ~5x higher — need bigger move to clear them
STOP_LOSS_PCT_LONG_EQUITY=1.5
STOP_LOSS_PCT_SHORT_EQUITY=1.5
TRAILING_STOP_PCT_EQUITY=0.8
TAKE_PROFIT_PCT_EQUITY=0.5
STOP_LOSS_PCT_LONG_COMMODITY=1.5
STOP_LOSS_PCT_SHORT_COMMODITY=1.5
TRAILING_STOP_PCT_COMMODITY=0.8
TAKE_PROFIT_PCT_COMMODITY=0.5
TRAILING_ACTIVATION_PCT=1.0           # Trailing stop only arms once position is this % in profit
TAKE_PROFIT_PCT=0.5                   # Fallback TP (used if asset class has no override); 0 = disabled
TIME_STOP_HOURS=0.5                   # 30-min hard kill — if thesis hasn't paid in 30 min, cut it
MIN_HOLD_MINUTES=3                    # Skip trailing/TP exits for first 3 min (0-5 min noise zone)

# ══════════════════════════════════════
# SIGNAL FILTERS
# ══════════════════════════════════════
ALLOWED_SIGNAL_TYPES=funding_rate,oi_divergence,volume_anomaly
ALLOWED_ASSETS=                       # Empty = trade everything Nexwave sends
BLOCKED_ASSETS=FARTCOIN,PENGU         # Never trade these
BLOCK_CRYPTO=false                    # Block plain-symbol signals (no venue prefix = crypto perp)

# ══════════════════════════════════════
# ALERTS (Optional)
# ══════════════════════════════════════
TELEGRAM_BOT_TOKEN=                   # From @BotFather
TELEGRAM_CHAT_ID=                     # Your chat or group ID

# ══════════════════════════════════════
# AGENT
# ══════════════════════════════════════
LOG_LEVEL=INFO
DB_PATH=./nexagent.db
API_PORT=7070
API_BIND=127.0.0.1                    # Use 0.0.0.0 for Render/cloud
API_KEY=                              # Optional: protect FastAPI endpoints
